*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{

    min-height:100vh;

    display:flex;
    justify-content:center;
    align-items:center;

    background:linear-gradient(135deg,#0f172a,#1e3a8a,#2563eb);

    padding:40px;

}

.container{

    width:1200px;
    max-width:100%;

    display:grid;

    grid-template-columns:1fr 1fr;

    gap:40px;

    align-items:center;

}

.left{

    color:white;

}

.left h1{

    font-size:45px;

    margin-bottom:20px;

    line-height:1.2;

}

.left p{

    font-size:18px;

    line-height:30px;

    opacity:.9;

    margin-bottom:35px;

}

.hero-image{

    width:100%;
    max-width:380px;

    animation:float 4s ease-in-out infinite;

}

@keyframes float{

    0%{
        transform:translateY(0px);
    }

    50%{
        transform:translateY(-15px);
    }

    100%{
        transform:translateY(0px);
    }

}

.right{

    display:flex;
    justify-content:center;

}

.card{

    width:100%;

    background:rgba(255,255,255,.15);

    backdrop-filter:blur(18px);

    border:1px solid rgba(255,255,255,.2);

    border-radius:25px;

    padding:35px;

    box-shadow:0 20px 50px rgba(0,0,0,.35);

}

.card h2{

    color:white;

    text-align:center;

    margin-bottom:25px;

}

label{

    display:block;

    color:white;

    margin-top:15px;

    margin-bottom:8px;

    font-weight:500;

}

select{

    width:100%;

    padding:14px;

    border:none;

    border-radius:12px;

    outline:none;

    font-size:15px;

    margin-bottom:5px;

}

button{

    width:100%;

    margin-top:25px;

    padding:16px;

    background:#06b6d4;

    color:white;

    border:none;

    border-radius:14px;

    font-size:18px;

    cursor:pointer;

    transition:.3s;

    font-weight:600;

}

button:hover{

    transform:translateY(-3px);

    background:#0891b2;

    box-shadow:0 10px 25px rgba(0,0,0,.25);

}

.result{

    margin-top:30px;

    background:white;

    border-radius:18px;

    padding:25px;

    text-align:center;

    animation:fade .5s ease;

}

.result h3{

    color:#2563eb;

    margin-bottom:12px;

}

.result h2{

    color:#111827;

    margin-top:5px;

}

@keyframes fade{

    from{

        opacity:0;
        transform:translateY(20px);

    }

    to{

        opacity:1;
        transform:translateY(0);

    }

}

@media(max-width:900px){

.container{

grid-template-columns:1fr;

}

.left{

text-align:center;

}

.hero-image{

margin:auto;
display:block;

}

.left h1{

font-size:34px;

}

}